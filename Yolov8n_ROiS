import os
import cv2
from ultralytics import YOLO

# 1. Define paths (Using the dynamic location from your Roboflow dataset)
test_img_dir = os.path.join(dataset.location, "test", "images")
output_crop_dir = "/content/pix2pix_dataset/metal_crops"
os.makedirs(output_crop_dir, exist_ok=True)

# 2. Load your best trained weights
model = YOLO("runs/detect/train/weights/best.pt")

# 3. Run prediction
# We keep save=False here because we only want to save the raw crops, not the annotated boxes
results = model.predict(
    source=test_img_dir,
    conf=0.25,
    save=False,
    verbose=False
)

crop_count = 0

# 4. Iterate through results and crop detections
for res in results:
    # Read the original raw image using OpenCV
    img_path = res.path
    img = cv2.imread(img_path)

    if img is None:
        continue

    img_base_name = os.path.splitext(os.path.basename(img_path))[0]

    # Check if any bounding boxes were detected
    if res.boxes is not None and len(res.boxes) > 0:
        # xyxy format returns coordinates as a tensor: [xmin, ymin, xmax, ymax]
        # We move it to CPU and convert to integers for pixel slicing
        boxes = res.boxes.xyxy.cpu().numpy().astype(int)

        for idx, box in enumerate(boxes):
            xmin, ymin, xmax, ymax = box

            # Defensive check: Ensure coordinates stay within the actual image boundaries
            xmin = max(0, xmin)
            ymin = max(0, ymin)
            xmax = min(img.shape[1], xmax)
            ymax = min(img.shape[0], ymax)

            # Crop the image using NumPy slicing: img[ymin:ymax, xmin:xmax]
            cropped_obj = img[ymin:ymax, xmin:xmax]

            # Check if the crop is valid and not empty
            if cropped_obj.size > 0:
                # Construct a unique filename (handles multiple detections per image)
                crop_filename = f"{img_base_name}_crop_{idx}.jpg"
                crop_save_path = os.path.join(output_crop_dir, crop_filename)

                # Save the cropped patch
                cv2.imwrite(crop_save_path, cropped_obj)
                crop_count += 1

print(f"✂️ Extraction Complete!")
print(f"Successfully cropped {crop_count} metal regions and saved them to: {output_crop_dir}")
