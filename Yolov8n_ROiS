metal_absent_imgs = []

# Loop over the raw prediction results to categorize images based on model output
for res in results:
    img_name = os.path.basename(res.path)

    # Check if YOLO detected boxes on this image
    if res.boxes is not None and len(res.boxes) > 0:
        if len(metal_present_imgs) < 10:
            metal_present_imgs.append(img_name)
    else:
        if len(metal_absent_imgs) < 10:
            metal_absent_imgs.append(img_name)

    # Break early if we successfully found 10 of each
    if len(metal_present_imgs) == 10 and len(metal_absent_imgs) == 10:
        break

# Combine both lists into a single target listing of 20 images total
selected_imgs = metal_present_imgs + metal_absent_imgs

print(f"Gathered {len(metal_present_imgs)} images WITH metal predictions.")
print(f"Gathered {len(metal_absent_imgs)} images WITHOUT metal predictions.")

# Set up a 4x5 grid layout (4 rows, 5 columns) to comfortably fit 20 images
fig, axes = plt.subplots(4, 5, figsize=(18, 14))
axes_flat = axes.flatten()

for idx, img_name in enumerate(selected_imgs):
    ax = axes_flat[idx]
    img_path = os.path.join(pred_dir, img_name)

