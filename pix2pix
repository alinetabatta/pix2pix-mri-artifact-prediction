from torch.optim import lr_scheduler


# Linear LR decay schedule. Defined here (before the schedulers) so the notebook runs
# top-to-bottom. It is also (identically) redefined later for backward compatibility.
def lr_lambda(epoch):
    decay_start_epoch = 100
    total_epochs = 200
    if epoch < decay_start_epoch:
        return 1.0
    return 1.0 - (epoch - decay_start_epoch) / (total_epochs - decay_start_epoch)


gen_scheduler = lr_scheduler.LambdaLR(generator_optimizer, lr_lambda=lr_lambda)
disc_scheduler = lr_scheduler.LambdaLR(discriminator_optimizer, lr_lambda=lr_lambda)


def generator_loss(disc_generated_output, gen_output, target):
    gan_loss = criterion_gan(
        disc_generated_output,
        torch.ones_like(disc_generated_output),
    )

    l1_loss = criterion_l1(gen_output, target)

    # Synthesis-oriented objective: adversarial term + light L1 anchor (no SSIM term).
    total_gen_loss = gan_loss + LAMBDA_L1 * l1_loss

    return total_gen_loss, gan_loss, l1_loss


def discriminator_loss(disc_real_output, disc_generated_output):
    real_loss = criterion_gan(
        disc_real_output,
        torch.ones_like(disc_real_output),
    )

    fake_loss = criterion_gan(
        disc_generated_output,
        torch.zeros_like(disc_generated_output),
    )

    return real_loss + fake_loss


def tensor_to_image(tensor):
    """Convert tensor [-1, 1] to numpy image [0, 1] for matplotlib."""
    tensor = tensor.detach().cpu().float()
    tensor = to_01(tensor)

    if tensor.shape[0] == 1:
        return tensor.squeeze(0).numpy()

    return tensor.permute(1, 2, 0).numpy()


@torch.no_grad()
def generate_images(
    model,
    test_input,
    target,
    epoch,
    save=True,
    split_name='Validation',
    filename_prefix='val',
):
    """Plot input, ground truth, and prediction for a fixed example.

    Parameters
    ----------
    model : torch.nn.Module
        Generator model.
    test_input : torch.Tensor
        Input image batch in [-1, 1].
    target : torch.Tensor
        Target image batch in [-1, 1].
    epoch : int
        Zero-based epoch index.
    save : bool
        If True, saves the figure to disk.
    split_name : str
        Name shown in the figure title, e.g., 'Training' or 'Validation'.
    filename_prefix : str
        Prefix used in the saved image filename.
    """
    model.eval()

    prediction = model(test_input.to(DEVICE))

