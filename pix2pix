def load_generator_from_checkpoint(checkpoint_path, device=DEVICE, prefer_ema=True):
    """Create a fresh GeneratorUNet and load weights from a checkpoint.

    Prefers the EMA weights when present (that is what was evaluated/selected during
    training); falls back to the raw generator weights otherwise.
    """
    checkpoint = torch.load(checkpoint_path, map_location=device)

    model = GeneratorUNet(
        in_channels=CHANNELS,
        out_channels=CHANNELS,
    ).to(device)

    ema_sd = checkpoint.get('generator_ema_state_dict', None)
    if prefer_ema and ema_sd is not None:
        model.load_state_dict(ema_sd)
        loaded = 'EMA'
    else:
        model.load_state_dict(checkpoint['generator_state_dict'])
        loaded = 'raw'

    model.eval()
    return model, checkpoint, loaded


