def pil_to_tensor_normalized(img, grayscale=True):
    """Convert PIL image to tensor [C,H,W] normalized to [-1, 1]."""
    arr = np.array(img).astype(np.float32) / 127.5 - 1.0

    if grayscale:
        # [H, W] -> [1, H, W]
        arr = arr[None, :, :]
    else:
        # [H, W, C] -> [C, H, W]
        arr = np.transpose(arr, (2, 0, 1))

    return torch.from_numpy(arr)


def paired_random_jitter(
    input_img,
    target_img,
    output_height=256,
    output_width=256,
    jitter_height=286,
    jitter_width=286,
    horizontal_flip=True,
):
    """Apply the same pix2pix-style random jitter to input and target PIL images.

    Steps:
    1. Resize both images to jitter_height x jitter_width.
    2. Randomly crop the same output_height x output_width region from both.
    3. Optionally apply the same horizontal flip to both.

    This keeps the scout/target pair spatially aligned.
    """

    if jitter_height < output_height or jitter_width < output_width:
        raise ValueError(
            'JITTER_RESIZE_HEIGHT/WIDTH must be >= IMG_HEIGHT/IMG_WIDTH.'
        )

    input_img = input_img.resize((jitter_width, jitter_height), BICUBIC)
    target_img = target_img.resize((jitter_width, jitter_height), BICUBIC)

    max_top = jitter_height - output_height
    max_left = jitter_width - output_width

    top = random.randint(0, max_top) if max_top > 0 else 0
    left = random.randint(0, max_left) if max_left > 0 else 0

    crop_box = (
        left,
        top,
        left + output_width,
        top + output_height,
    )

    input_img = input_img.crop(crop_box)
    target_img = target_img.crop(crop_box)

    if horizontal_flip and random.random() > 0.5:
        input_img = input_img.transpose(Image.Transpose.FLIP_LEFT_RIGHT)
        target_img = target_img.transpose(Image.Transpose.FLIP_LEFT_RIGHT)

    return input_img, target_img


class MRIPairedDataset(Dataset):
    """Paired scout -> target dataset with optional paired jitter augmentation.

    The target path is obtained by replacing 'knee_scout' with 'knee_pdfs'.
    This follows your original TensorFlow/PyTorch pairing logic.

    When augment=True and min_size is larger than the number of original files,
    the dataset is virtually expanded by repeating file paths. Each repeated
    sample receives a new random jitter, so one epoch contains at least min_size
    augmented training examples without saving duplicated images to disk.
    """

    def __init__(
        self,
        scout_dir,
        img_height=256,
        img_width=256,
        grayscale=True,
        augment=False,
        min_size=None,
        jitter_height=286,
        jitter_width=286,
        horizontal_flip=True,
    ):
        self.scout_dir = scout_dir
        self.img_height = img_height
        self.img_width = img_width
        self.grayscale = grayscale
        self.augment = augment
        self.min_size = min_size
        self.jitter_height = jitter_height
        self.jitter_width = jitter_width
        self.horizontal_flip = horizontal_flip

        extensions = ('*.png', '*.jpg', '*.jpeg', '*.bmp', '*.tif', '*.tiff')
        self.files = []
        for ext in extensions:
            self.files.extend(Path(scout_dir).glob(ext))

        self.files = sorted([str(f) for f in self.files])

        if len(self.files) == 0:
            raise ValueError(f'No images found in: {scout_dir}')

        if self.augment and self.min_size is not None:
            self.effective_size = max(len(self.files), int(self.min_size))
        else:
            self.effective_size = len(self.files)

    def __len__(self):
        return self.effective_size

    def _open_image(self, path):
        if self.grayscale:
            return Image.open(path).convert('L')
        return Image.open(path).convert('RGB')

    def __getitem__(self, idx):
        # Use modulo indexing so the original paired images are repeated until
        # the virtual augmented dataset reaches MIN_TRAIN_IMAGES.
        scout_file = self.files[idx % len(self.files)]
        target_file = scout_file.replace('knee_scout', 'knee_pdfs')

        if not os.path.exists(target_file):
            raise FileNotFoundError(
                f'Target not found for {scout_file}: {target_file}'
            )

        input_img = self._open_image(scout_file)
        target_img = self._open_image(target_file)

        if self.augment:
            input_img, target_img = paired_random_jitter(
                input_img,
                target_img,
                output_height=self.img_height,
                output_width=self.img_width,
                jitter_height=self.jitter_height,
                jitter_width=self.jitter_width,
                horizontal_flip=self.horizontal_flip,
            )
        else:
            input_img = input_img.resize((self.img_width, self.img_height), BICUBIC)
            target_img = target_img.resize((self.img_width, self.img_height), BICUBIC)

        input_image = pil_to_tensor_normalized(input_img, grayscale=self.grayscale)
        target_image = pil_to_tensor_normalized(target_img, grayscale=self.grayscale)

        return input_image, target_image


