@torch.no_grad()
def plot_dataset_results(
    model,
    dataset,
    split_name,
    output_dir,
    max_samples=None,
    random_subset=False,
    seed=42,
    batch_size=1,
    show=False,
):
    """Plot model results for a full dataset or for a random subset.

    The function saves one figure per sample with three panels:
    input, ground truth, and prediction.

    Parameters
    ----------
    model : torch.nn.Module
        Generator model.
    dataset : torch.utils.data.Dataset
        Dataset to evaluate.
    split_name : str
        Name used in figure titles and filenames.
    output_dir : str
        Folder where the result images will be saved.
    max_samples : int or None
        Number of samples to plot. If None, plots the full dataset.
    random_subset : bool
        If True, randomly samples max_samples indices from the dataset.
    seed : int
        Random seed used when random_subset=True.
    batch_size : int
        Batch size for plotting. The function saves one image per sample.
    show : bool
        If True, displays each figure in the notebook. For large validation/test
        sets, keep this False to avoid a very large notebook output.
    """
    os.makedirs(output_dir, exist_ok=True)
    n_total = len(dataset)

    if max_samples is None or max_samples >= n_total:
        indices = list(range(n_total))
    else:
        if random_subset:
            rng = random.Random(seed)
            indices = sorted(rng.sample(range(n_total), max_samples))
        else:
            indices = list(range(max_samples))

    subset = Subset(dataset, indices)
    loader = DataLoader(
        subset,
        batch_size=batch_size,
        shuffle=False,
        num_workers=NUM_WORKERS,
        pin_memory=(DEVICE.type == 'cuda'),
        worker_init_fn=seed_worker if NUM_WORKERS > 0 else None,
    )

    saved_files = []
    model.eval()

    for batch_id, (input_batch, target_batch) in enumerate(loader):
        current_batch_size = input_batch.shape[0]
        for j in range(current_batch_size):
            local_pos = batch_id * batch_size + j
            original_index = indices[local_pos]
            saved_file = plot_single_result(
                model=model,
                input_image=input_batch[j],
                target=target_batch[j],
                split_name=split_name,
                sample_index=original_index,
                output_dir=output_dir,
                save=True,
                show=show,
            )
            saved_files.append(saved_file)

    model.eval()
    print(f'{split_name}: saved {len(saved_files)} result figures in: {output_dir}')
    return saved_files


# =========================================================
# Feature extractor for KID (RadImageNet trunk, or fallback)
# =========================================================
from torch.utils.data import ConcatDataset


class ResNet50Features(nn.Module):
    """ResNet50 trunk returning 2048-d pooled features for KID.

    Accepts uint8 [0,255] (the dtype torchmetrics passes when normalize=False) or float
    images, resizes to 224, and applies the chosen normalization. Load RadImageNet weights
    via weights_path; otherwise optionally use the ImageNet-pretrained trunk.
    """

    def __init__(self, weights_path=None, imagenet=False, normalize_mode='imagenet'):
        super().__init__()
        try:
            net = resnet50(weights='IMAGENET1K_V2' if imagenet else None)
        except TypeError:
            net = resnet50(pretrained=imagenet)
        net.fc = nn.Identity()
        self.net = net
        self.normalize_mode = normalize_mode

        if weights_path is not None and os.path.exists(weights_path):
            sd = torch.load(weights_path, map_location='cpu')
            if isinstance(sd, dict) and 'state_dict' in sd:
                sd = sd['state_dict']
            cleaned = {}
            for k, v in sd.items():
                nk = k
                for pref in ('module.', 'backbone.', 'model.', 'encoder.'):
                    if nk.startswith(pref):
                        nk = nk[len(pref):]
                cleaned[nk] = v
            missing, unexpected = self.net.load_state_dict(cleaned, strict=False)
            print(f'[KID] Loaded RadImageNet weights from: {weights_path}')
            print(f'[KID] missing keys: {len(missing)} | unexpected keys: {len(unexpected)}')

        for p in self.net.parameters():
            p.requires_grad_(False)
        self.net.eval()

        self.register_buffer('mean', torch.tensor([0.485, 0.456, 0.406]).view(1, 3, 1, 1))
        self.register_buffer('std', torch.tensor([0.229, 0.224, 0.225]).view(1, 3, 1, 1))

    @torch.no_grad()
    def forward(self, x):
        if x.dtype == torch.uint8:
            x = x.float() / 255.0
        else:
            x = x.float()
            if x.max() > 1.5:
                x = x / 255.0
        x = F.interpolate(x, size=(224, 224), mode='bilinear', align_corners=False)
        if self.normalize_mode == 'imagenet':
            x = (x - self.mean) / self.std
        return self.net(x)


# Built once and reused so RadImageNet weights are not reloaded every epoch.
_KID_FEATURE = None
_KID_BACKEND = None
_KID_ANNOUNCED = False


def get_kid_feature():
    global _KID_FEATURE, _KID_BACKEND
    if _KID_FEATURE is not None:
        return _KID_FEATURE, _KID_BACKEND

    if RADIMAGENET_WEIGHTS_PATH is not None and os.path.exists(RADIMAGENET_WEIGHTS_PATH):
        _KID_FEATURE = ResNet50Features(
            weights_path=RADIMAGENET_WEIGHTS_PATH, imagenet=False,
            normalize_mode=RADIMAGENET_NORMALIZE,
        ).to(DEVICE)
        _KID_BACKEND = 'RadImageNet-ResNet50'
    elif KID_FALLBACK == 'imagenet_resnet50':
        _KID_FEATURE = ResNet50Features(
            weights_path=None, imagenet=True, normalize_mode='imagenet',
        ).to(DEVICE)
        _KID_BACKEND = 'ImageNet-ResNet50'
    else:
        _KID_FEATURE = 2048  # torchmetrics default InceptionV3
        _KID_BACKEND = 'ImageNet-InceptionV3'

    return _KID_FEATURE, _KID_BACKEND


def build_kid_metric(num_real, num_fake):
    """KID metric with subset_size capped at min(real pool, fakes)."""
    subset_size = max(2, min(KID_SUBSET_SIZE, num_real, num_fake))
    feature, backend = get_kid_feature()
    kid = KernelInceptionDistance(
        feature=feature,
        subsets=KID_SUBSETS,
        subset_size=subset_size,
        normalize=False,  # we feed uint8 [0,255]
    ).to(DEVICE)
    return kid, subset_size, backend


def build_real_pool_loader(batch_size=None, cap=None, splits=('train', 'val', 'test')):
    """DataLoader over real PD-FS targets pooled across splits, for the KID 'real' side.

    KID does not need paired real/fake, so the real distribution can be estimated from many
    more images than the eval split contains. cap=None uses every image in the chosen splits.
    """
    dir_map = {'train': train_scout_dir, 'val': val_scout_dir, 'test': test_scout_dir}
    datasets = [
        MRIPairedDataset(dir_map[s], IMG_HEIGHT, IMG_WIDTH, grayscale=USE_GRAYSCALE, augment=False)
        for s in splits
    ]
    pool = ConcatDataset(datasets)
    if cap is not None and cap < len(pool):
        g = torch.Generator().manual_seed(SEED)
        idx = torch.randperm(len(pool), generator=g)[:cap].tolist()
        pool = Subset(pool, idx)
    if batch_size is None:
        batch_size = KID_POOL_BATCH
    return DataLoader(
        pool, batch_size=batch_size, shuffle=False, num_workers=NUM_WORKERS,
        pin_memory=(DEVICE.type == 'cuda'),
    )


@torch.no_grad()
def evaluate_model_metrics_silent(model, loader, real_pool_loader=None):
    """Sanity metrics (MSE / PSNR / SSIM / LPIPS) plus KID for realism.

    real_pool_loader: optional loader whose *targets* form the KID 'real' distribution
    (pooled across splits). When provided, the eval loader contributes only the fakes
    (model predictions); the eval targets are not added again. When None, the eval targets
    are used as the real side (original behaviour).
    """
    model.eval()

    mse_list, psnr_list, ssim_list, lpips_list = [], [], [], []

    num_fake = len(loader.dataset)
    num_real = len(real_pool_loader.dataset) if real_pool_loader is not None else num_fake
    kid_metric, kid_subset, kid_backend = build_kid_metric(num_real, num_fake)
    lpips_metric = LearnedPerceptualImagePatchSimilarity(net_type='alex').to(DEVICE)

    global _KID_ANNOUNCED
    if not _KID_ANNOUNCED:
        print(f'[KID] backend: {kid_backend} | subset_size: {kid_subset} '
              f'| real pool: {num_real} | fakes: {num_fake}')
        _KID_ANNOUNCED = True

    def to_uint8_3ch(img01):
        if img01.shape[1] == 1:
            img01 = img01.repeat(1, 3, 1, 1)
        return (img01.clamp(0, 1) * 255).to(torch.uint8)

    # Fakes (and pixel metrics) from the paired eval loader.
    for input_image, target in loader:
        input_image = input_image.to(DEVICE, non_blocking=True)
        target = target.to(DEVICE, non_blocking=True)

        prediction = model(input_image)

        target_norm = to_01(target)
        prediction_norm = to_01(prediction)

        # Pixel sanity metrics on [0, 1]
        mse_batch = torch.mean((target_norm - prediction_norm) ** 2, dim=(1, 2, 3))
        psnr_batch = 10.0 * torch.log10(1.0 / (mse_batch + 1e-12))
        ssim_batch = ssim_torch(target_norm, prediction_norm, max_val=1.0)

        mse_list.extend(mse_batch.cpu().numpy())
        psnr_list.extend(psnr_batch.cpu().numpy())
        ssim_list.extend(ssim_batch.cpu().numpy())

        # LPIPS expects [-1, 1], 3-channel
        if target.shape[1] == 1:
            target_3ch = target.repeat(1, 3, 1, 1)
            pred_3ch = prediction.repeat(1, 3, 1, 1)
        else:
            target_3ch, pred_3ch = target, prediction
        lpips_list.append(lpips_metric(pred_3ch.clamp(-1, 1), target_3ch.clamp(-1, 1)).item())

        # KID fakes (uint8 [0,255], 3-channel)
        kid_metric.update(to_uint8_3ch(prediction_norm), real=False)
        if real_pool_loader is None:
            kid_metric.update(to_uint8_3ch(target_norm), real=True)

    # KID reals from the pooled real PD-FS loader (preferred).
    if real_pool_loader is not None:
        for batch in real_pool_loader:
            real_imgs = batch[1] if isinstance(batch, (list, tuple)) else batch
            real_imgs = real_imgs.to(DEVICE, non_blocking=True)
            kid_metric.update(to_uint8_3ch(to_01(real_imgs)), real=True)

    kid_mean, kid_std = kid_metric.compute()

    return (
        float(np.mean(mse_list)),
        float(np.mean(psnr_list)),
        float(np.mean(ssim_list)),
        float(kid_mean.item()),
        float(kid_std.item()),
        float(np.mean(lpips_list)),
    )


# =========================================================
# DiffAugment (Zhao et al., 2020): differentiable augmentation applied to the
# discriminator's inputs only. The generator always sees the raw input image.
# =========================================================
def rand_brightness(x):
    x = x + (torch.rand(x.size(0), 1, 1, 1, dtype=x.dtype, device=x.device) - 0.5)
    return x


def rand_saturation(x):
    # On a stacked (condition, image) tensor with 1-channel inputs this couples the two
    # channels slightly; it only regularises the discriminator and is bounded.
    x_mean = x.mean(dim=1, keepdim=True)
    x = (x - x_mean) * (torch.rand(x.size(0), 1, 1, 1, dtype=x.dtype, device=x.device) * 2) + x_mean
    return x


def rand_contrast(x):
    x_mean = x.mean(dim=[1, 2, 3], keepdim=True)
    x = (x - x_mean) * (torch.rand(x.size(0), 1, 1, 1, dtype=x.dtype, device=x.device) + 0.5) + x_mean
    return x


def rand_translation(x, ratio=0.125):
    shift_x = int(x.size(2) * ratio + 0.5)
    shift_y = int(x.size(3) * ratio + 0.5)
    translation_x = torch.randint(-shift_x, shift_x + 1, size=[x.size(0), 1, 1], device=x.device)
    translation_y = torch.randint(-shift_y, shift_y + 1, size=[x.size(0), 1, 1], device=x.device)
    grid_batch, grid_x, grid_y = torch.meshgrid(
        torch.arange(x.size(0), dtype=torch.long, device=x.device),
        torch.arange(x.size(2), dtype=torch.long, device=x.device),
        torch.arange(x.size(3), dtype=torch.long, device=x.device),
        indexing='ij',
    )
    grid_x = torch.clamp(grid_x + translation_x + 1, 0, x.size(2) + 1)
    grid_y = torch.clamp(grid_y + translation_y + 1, 0, x.size(3) + 1)
    x_pad = F.pad(x, [1, 1, 1, 1, 0, 0, 0, 0])
    x = x_pad.permute(0, 2, 3, 1).contiguous()[grid_batch, grid_x, grid_y]
    x = x.permute(0, 3, 1, 2).contiguous()
    return x


def rand_cutout(x, ratio=0.5):
    cut_x = int(x.size(2) * ratio + 0.5)
    cut_y = int(x.size(3) * ratio + 0.5)
    offset_x = torch.randint(0, x.size(2) + (1 - cut_x % 2), size=[x.size(0), 1, 1], device=x.device)
    offset_y = torch.randint(0, x.size(3) + (1 - cut_y % 2), size=[x.size(0), 1, 1], device=x.device)
    grid_batch, grid_x, grid_y = torch.meshgrid(
        torch.arange(x.size(0), dtype=torch.long, device=x.device),
        torch.arange(cut_x, dtype=torch.long, device=x.device),
        torch.arange(cut_y, dtype=torch.long, device=x.device),
        indexing='ij',
    )
    grid_x = torch.clamp(grid_x + offset_x - cut_x // 2, min=0, max=x.size(2) - 1)
    grid_y = torch.clamp(grid_y + offset_y - cut_y // 2, min=0, max=x.size(3) - 1)
    mask = torch.ones(x.size(0), x.size(2), x.size(3), dtype=x.dtype, device=x.device)
    mask[grid_batch, grid_x, grid_y] = 0
    x = x * mask.unsqueeze(1)
    return x


AUGMENT_FNS = {
    'color': [rand_brightness, rand_saturation, rand_contrast],
    'translation': [rand_translation],
    'cutout': [rand_cutout],
}


def DiffAugment(x, policy=''):
    if not policy:
        return x
    for p in policy.split(','):
        p = p.strip()
        if not p:
            continue
        for f in AUGMENT_FNS[p]:
            x = f(x)
    return x.contiguous()


def discriminator_on_pair(disc, cond, img, policy=''):
    """Concatenate (condition, image), DiffAugment the pair together so spatial
    transforms stay aligned, then run the conditional PatchGAN discriminator."""
    pair = torch.cat([cond, img], dim=1)
    if policy:
        pair = DiffAugment(pair, policy=policy)
    cond_a = pair[:, :CHANNELS]
    img_a = pair[:, CHANNELS:]
    return disc(cond_a, img_a)


# =========================================================
# Generator EMA update
# =========================================================
@torch.no_grad()
def update_ema(ema_model, model, decay):
    """In-place EMA update of ema_model towards model. decay=0 copies model exactly."""
    ema_params = dict(ema_model.named_parameters())
    for name, param in model.named_parameters():
        ema_params[name].mul_(decay).add_(param.detach(), alpha=1.0 - decay)
    ema_buffers = dict(ema_model.named_buffers())
    for name, buf in model.named_buffers():
        if name in ema_buffers:
            ema_buffers[name].copy_(buf)


# =========================================================
# R1 gradient penalty on real images
# =========================================================
def r1_penalty(disc, cond, real_img):
    """R1 = E[ || grad_x D(cond, x) ||^2 ] on real images x.

    Computed on the raw (non-DiffAugment) reals for numerical robustness; the gradient is
    taken only w.r.t. the real image, with the condition held fixed.
    """
    real_img = real_img.detach().requires_grad_(True)
    disc_real = discriminator_on_pair(disc, cond, real_img, policy='')
    grad = torch.autograd.grad(
        outputs=disc_real.sum(),
        inputs=real_img,
        create_graph=True,
        retain_graph=True,
        only_inputs=True,
    )[0]
    return grad.pow(2).flatten(1).sum(1).mean()


def train_step(input_image, target, global_step):
    input_image = input_image.to(DEVICE, non_blocking=True)
    target = target.to(DEVICE, non_blocking=True)

    policy = DIFFAUG_POLICY if USE_DIFFAUGMENT else ''

    # =========================================================
    # 1) Update discriminator (D_STEPS_PER_G times; default: once)
    # =========================================================
    d_loss_value = np.nan
    r1_value = np.nan
    for _ in range(D_STEPS_PER_G):
        discriminator_optimizer.zero_grad(set_to_none=True)

        with torch.no_grad():
            gen_output_detached = generator(input_image)

        disc_real_output = discriminator_on_pair(discriminator, input_image, target, policy)
        disc_generated_output = discriminator_on_pair(discriminator, input_image, gen_output_detached, policy)

        d_loss = discriminator_loss(disc_real_output, disc_generated_output)
        d_loss_value = d_loss.item()  # log the adversarial part only

        # R1 gradient penalty on real images (off by default; see config).
        # Weight R1_GAMMA/2, no lazy interval multiplier, linearly warmed up so the large
        # initial gradient norms do not collapse the discriminator.
        if USE_R1 and (global_step % R1_INTERVAL == 0):
            r1 = r1_penalty(discriminator, input_image, target)
            warmup = min(1.0, (global_step + 1) / max(1, R1_WARMUP_STEPS))
            d_loss = d_loss + (R1_GAMMA / 2.0) * r1 * warmup
            r1_value = r1.item()

        d_loss.backward()
        discriminator_optimizer.step()

    # =========================================================
    # 2) Update generator (once). DiffAugment is differentiable, so G receives
    #    gradients through the augmentation applied to the fake pair.
    # =========================================================
    generator_optimizer.zero_grad(set_to_none=True)

    gen_output = generator(input_image)
    disc_generated_output = discriminator_on_pair(discriminator, input_image, gen_output, policy)

    gen_total_loss, gen_gan_loss, gen_l1_loss = generator_loss(
        disc_generated_output, gen_output, target
    )

    gen_total_loss.backward()
    generator_optimizer.step()

    # =========================================================
    # 3) EMA update of the generator weights.
    # =========================================================
    if USE_EMA:
        decay = EMA_DECAY if global_step >= EMA_START_STEP else 0.0
        update_ema(generator_ema, generator, decay)

    return gen_total_loss.item(), gen_gan_loss.item(), gen_l1_loss.item(), d_loss_value, r1_value


def save_checkpoint(epoch, history, filename,
                    last_val_mse=None, last_val_psnr=None, last_val_ssim=None,
                    last_val_kid_mean=None, last_val_kid_std=None, last_val_lpips=None):
    ckpt_path = os.path.join(PATH, filename)

    payload = {
        'epoch': epoch + 1,
        'generator_state_dict': generator.state_dict(),
        'generator_ema_state_dict': generator_ema.state_dict() if USE_EMA else None,
        'discriminator_state_dict': discriminator.state_dict(),
        'generator_optimizer_state_dict': generator_optimizer.state_dict(),
        'discriminator_optimizer_state_dict': discriminator_optimizer.state_dict(),
        'history': history,
        'config': {
            'IMG_WIDTH': IMG_WIDTH,
            'IMG_HEIGHT': IMG_HEIGHT,
            'USE_GRAYSCALE': USE_GRAYSCALE,
            'CHANNELS': CHANNELS,
            'LAMBDA_L1': LAMBDA_L1,
            'GEN_LR': GEN_LR,
            'DISC_LR': DISC_LR,
            'D_STEPS_PER_G': D_STEPS_PER_G,
            'USE_DIFFAUGMENT': USE_DIFFAUGMENT,
            'DIFFAUG_POLICY': DIFFAUG_POLICY,
            'USE_EMA': USE_EMA,
            'EMA_DECAY': EMA_DECAY,
            'USE_R1': USE_R1,
            'R1_GAMMA': R1_GAMMA,
            'R1_INTERVAL': R1_INTERVAL,
            'USE_DATA_AUGMENTATION': USE_DATA_AUGMENTATION,
            'TARGET_TRAIN_IMAGES_WITH_AUGMENTATION': TARGET_TRAIN_IMAGES_WITH_AUGMENTATION,
            'JITTER_RESIZE_HEIGHT': JITTER_RESIZE_HEIGHT,
            'JITTER_RESIZE_WIDTH': JITTER_RESIZE_WIDTH,
            'RANDOM_HORIZONTAL_FLIP': RANDOM_HORIZONTAL_FLIP,
            'RADIMAGENET_WEIGHTS_PATH': RADIMAGENET_WEIGHTS_PATH,
            'KID_FALLBACK': KID_FALLBACK,
            'KID_REAL_POOL_SIZE': KID_REAL_POOL_SIZE,
        },
    }

    for key, value in [
        ('last_val_mse', last_val_mse),
        ('last_val_psnr', last_val_psnr),
        ('last_val_ssim', last_val_ssim),
        ('last_val_kid_mean', last_val_kid_mean),
        ('last_val_kid_std', last_val_kid_std),
        ('last_val_lpips', last_val_lpips),
    ]:
        if value is not None:
            payload[key] = value

    torch.save(payload, ckpt_path)
    return ckpt_path


def fit(train_loader, epochs, val_loader):
    history = {
        'gen_total_loss': [], 'gen_gan_loss': [], 'gen_l1_loss': [], 'disc_loss': [], 'disc_r1': [],
        'val_mse': [], 'val_psnr': [], 'val_ssim': [],
        'val_kid_mean': [], 'val_kid_std': [], 'val_lpips': [],
    }

    best_val_kid = float('inf')
    global_step = 0

    # Model used for evaluation / sampling: the EMA copy when enabled.
    eval_model = generator_ema if USE_EMA else generator

    # Real PD-FS pool for the KID 'real' side (pooled across splits, capped for speed).
    real_pool_loader = build_real_pool_loader(cap=KID_REAL_POOL_SIZE)

    # Fixed examples for visual monitoring during training.
    train_example_input, train_example_target = next(iter(train_loader))
    val_example_input, val_example_target = next(iter(val_loader))

    for epoch in range(epochs):
        start = time.time()

        generator.train()
        discriminator.train()

        epoch_gen_total, epoch_gen_gan, epoch_gen_l1, epoch_disc, epoch_r1 = [], [], [], [], []

        for n, (input_image, target) in enumerate(train_loader):
            gen_total_loss, gen_gan_loss, gen_l1_loss, d_loss, r1_val = train_step(
                input_image, target, global_step
            )
            global_step += 1

            epoch_gen_total.append(gen_total_loss)
            epoch_gen_gan.append(gen_gan_loss)
            epoch_gen_l1.append(gen_l1_loss)
            if not np.isnan(d_loss):
                epoch_disc.append(d_loss)
            if not np.isnan(r1_val):
                epoch_r1.append(r1_val)

            if n % 10 == 0:
                print(
                    f'\rEpoch {epoch + 1}/{epochs} | Step {n}/{len(train_loader)} | '
                    f'G: {gen_total_loss:.4f} | L1: {gen_l1_loss:.4f} | '
                    f'D: {d_loss if not np.isnan(d_loss) else 0.0:.4f}',
                    end='',
                )

        # Mean training losses
        history['gen_total_loss'].append(float(np.mean(epoch_gen_total)))
        history['gen_gan_loss'].append(float(np.mean(epoch_gen_gan)))
        history['gen_l1_loss'].append(float(np.mean(epoch_gen_l1)))
        history['disc_loss'].append(float(np.mean(epoch_disc)) if len(epoch_disc) > 0 else np.nan)
        history['disc_r1'].append(float(np.mean(epoch_r1)) if len(epoch_r1) > 0 else np.nan)

        # Validation metrics on the EMA model; KID against the pooled real set.
        val_mse, val_psnr, val_ssim, val_kid_mean, val_kid_std, val_lpips = \
            evaluate_model_metrics_silent(eval_model, val_loader, real_pool_loader=real_pool_loader)
        history['val_mse'].append(val_mse)
        history['val_psnr'].append(val_psnr)
        history['val_ssim'].append(val_ssim)
        history['val_kid_mean'].append(val_kid_mean)
        history['val_kid_std'].append(val_kid_std)
        history['val_lpips'].append(val_lpips)

        print(
            f'\nEpoch {epoch + 1}/{epochs} finished in {time.time() - start:.2f} s | '
            f'KID(EMA): {val_kid_mean:.4f} +/- {val_kid_std:.4f} | LPIPS: {val_lpips:.4f} | '
            f'PSNR: {val_psnr:.2f} dB | SSIM: {val_ssim:.4f} (sanity)'
        )

        # Save latest checkpoint (stores both raw and EMA generator weights)
        save_checkpoint(
            epoch, history, filename='mri_pix2pix_pytorch_modified_last_epoch.pth',
            last_val_mse=val_mse, last_val_psnr=val_psnr, last_val_ssim=val_ssim,
            last_val_kid_mean=val_kid_mean, last_val_kid_std=val_kid_std, last_val_lpips=val_lpips,
        )

        # Best checkpoint = lowest validation KID of the EMA model
        if val_kid_mean < best_val_kid:
            best_val_kid = val_kid_mean
            best_path = save_checkpoint(
                epoch, history, filename='mri_pix2pix_pytorch_modified_best_kid.pth',
                last_val_mse=val_mse, last_val_psnr=val_psnr, last_val_ssim=val_ssim,
                last_val_kid_mean=val_kid_mean, last_val_kid_std=val_kid_std, last_val_lpips=val_lpips,
            )
            print(f'Best checkpoint saved: {best_path} | Best Val KID: {best_val_kid:.4f}')

        # Step schedulers at the end of the epoch
        gen_scheduler.step()
        disc_scheduler.step()

        # Visual progress saves (from the EMA model)
        generate_images(eval_model, train_example_input, train_example_target, epoch, save=True, split_name='Training', filename_prefix='train')
        generate_images(eval_model, val_example_input, val_example_target, epoch, save=True, split_name='Validation', filename_prefix='val')

    return history


def plot_train_history(history, save_path=None, dpi=300):
    plots = [
        ('gen_total_loss', 'Total Generator Loss', 'Loss'),
        ('gen_gan_loss', 'Generator GAN Loss', 'Loss'),
        ('gen_l1_loss', 'Generator L1 Loss', 'Loss'),
        ('disc_loss', 'Discriminator Loss', 'Loss'),
        ('disc_r1', 'Discriminator R1 penalty', 'R1'),
        ('val_kid_mean', 'Validation KID (lower = better)', 'KID'),
        ('val_lpips', 'Validation LPIPS (lower = better)', 'LPIPS'),
        ('val_psnr', 'Validation PSNR (sanity)', 'PSNR (dB)'),
        ('val_ssim', 'Validation SSIM (sanity)', 'SSIM'),
    ]

    for key, title, ylabel in plots:
        if key not in history or len(history[key]) == 0:
            continue
        if np.all(np.isnan(np.array(history[key], dtype=float))):
            continue

        plt.figure(figsize=(7, 5))
        plt.plot(history[key], label=key)

        # Shade KID +/- std if available.
        if key == 'val_kid_mean' and 'val_kid_std' in history and len(history['val_kid_std']) == len(history[key]):
            m = np.array(history['val_kid_mean'])
            s = np.array(history['val_kid_std'])
            xs = np.arange(len(m))
            plt.fill_between(xs, m - s, m + s, alpha=0.2)

        plt.title(title)
        plt.xlabel('Epoch')
        plt.ylabel(ylabel)
        plt.grid(True)
        plt.legend()
        plt.tight_layout()

        if save_path is not None:
            os.makedirs(save_path, exist_ok=True)
            plt.savefig(os.path.join(save_path, f'{key}.png'), dpi=dpi, bbox_inches='tight')

        plt.show()


def lr_lambda(epoch):
    # Total epochs = 200, Decay starts at 100
    decay_start_epoch = 100
    total_epochs = 200

    if epoch < decay_start_epoch:
        return 1.0
    else:
        # Linearly decrease from 1.0 to 0.0
        return 1.0 - (epoch - decay_start_epoch) / (total_epochs - decay_start_epoch)

